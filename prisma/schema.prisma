generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  memberships      BusinessMember[]
  sentInvites      BusinessInvite[]        @relation("InvitedBy")
  sheetsConnection GoogleSheetsConnection?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum BusinessRole {
  founder
  accountant
  reviewer
}

model ReportSnapshot {
  id         String @id @default(cuid())
  businessId String

  cashBufferDays      Int
  cashBufferRiskLevel String
  totalCashInflows    Float
  totalCashOutflows   Float
  mixedFundsCount     Int
  mixedFundsTotal     Float
  flagsJson           Json
  plainLanguageJson   Json

  generatedAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, generatedAt])
}

model Business {
  id          String @id @default(cuid())
  slug        String @unique
  companyName String
  branchCount Int    @default(1)
  currency    String @default("KES")

  members         BusinessMember[]
  invites         BusinessInvite[]
  transactions    Transaction[]
  invoices        Invoice[]
  bankStatements  BankStatement[]
  documents       SupportingDocument[]
  zohoConnection  ZohoConnection?
  reportSnapshots ReportSnapshot[]
  uploadedFiles   UploadedFile[]
  flagResponses   FlagResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessMember {
  id         String       @id @default(cuid())
  businessId String
  userId     String
  role       BusinessRole @default(founder)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([businessId, userId])
}

model BusinessInvite {
  id          String       @id @default(cuid())
  businessId  String
  email       String
  role        BusinessRole @default(accountant)
  invitedById String
  acceptedAt  DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InvitedBy", fields: [invitedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([businessId, email])
}

// ─────────────────────────────────────────────────────────────────────
// FLAG RESPONSES — founder feedback on individual flags.
// Keyed on (businessId, flagTitle) because flags don't have stable IDs
// across engine runs — the title is the only stable identifier.
// One row per flag per business, upserted on every response change.
// ─────────────────────────────────────────────────────────────────────
model FlagResponse {
  id           String @id @default(cuid())
  businessId   String
  flagTitle    String // matches FlagItem.title exactly
  response     String // 'already_handled' | 'intentional' | 'need_help'
  respondedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, flagTitle])
  @@index([businessId])
}

model UploadedFile {
  id         String @id @default(cuid())
  businessId String

  filename   String
  fileKind   String
  rowCount   Int
  dateFrom   String?
  dateTo     String?
  uploadedAt DateTime @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
}

model Transaction {
  id              String   @id @default(cuid())
  businessId      String
  transactionId   String
  date            DateTime
  branch          String
  type            String
  accountName     String
  categoryName    String
  contactName     String
  referenceNumber String
  paymentMethod   String
  description     String
  amount          Float
  status          String
  bankAccount     String
  isReconciled    Boolean  @default(false)
  notes           String   @default("")

  sourceFileId String?
  sourceFile   UploadedFile? @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([businessId, transactionId])
  @@index([businessId])
  @@index([sourceFileId])
}

model Invoice {
  id              String   @id @default(cuid())
  businessId      String
  invoiceId       String
  customerName    String
  total           Float
  balance         Float
  status          String
  date            DateTime
  dueDate         DateTime
  referenceNumber String
  branch          String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, invoiceId])
  @@index([businessId])
}

model BankStatement {
  id             String   @id @default(cuid())
  businessId     String
  statementId    String
  dateFrom       DateTime
  dateTo         DateTime
  openingBalance Float
  closingBalance Float
  reconciled     Boolean  @default(false)
  notes          String   @default("")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, statementId])
  @@index([businessId])
}

model SupportingDocument {
  id               String @id @default(cuid())
  businessId       String
  documentKind     String
  sourceFilename   String
  extractionMethod String
  confidence       String
  lineItemsJson    Json
  metadataJson     Json
  warningsJson     Json

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId])
}

model ZohoConnection {
  id             String  @id @default(cuid())
  businessId     String  @unique
  refreshToken   String
  apiDomain      String
  organizationId String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  connectedAt DateTime @default(now())
}

model GoogleSheetsConnection {
  id           String @id @default(cuid())
  userId       String @unique
  refreshToken String @db.Text
  email        String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectedAt DateTime @default(now())
}