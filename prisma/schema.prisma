// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  memberships      BusinessMember[]
  sentInvites      BusinessInvite[]        @relation("InvitedBy")
  sheetsConnection GoogleSheetsConnection?

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  emailVerification EmailVerification?
  kotaniCustomerKey String?
  kotaniOrders      KotaniPaymentOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum BusinessRole {
  founder
  accountant
  reviewer
}

model ReportSnapshot {
  id         String @id @default(cuid())
  businessId String

  cashBufferDays      Int
  cashBufferRiskLevel String
  totalCashInflows    Float
  totalCashOutflows   Float
  mixedFundsCount     Int
  mixedFundsTotal     Float
  flagsJson           Json
  plainLanguageJson   Json

  generatedAt DateTime @default(now())

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  anchorTxHash String?
  anchorStatus String?

  @@index([businessId, generatedAt])
}

model Business {
  id          String @id @default(cuid())
  slug        String @unique
  companyName String
  branchCount Int    @default(1)
  currency    String @default("KES")

  members         BusinessMember[]
  invites         BusinessInvite[]
  transactions    Transaction[]
  invoices        Invoice[]
  bankStatements  BankStatement[]
  documents       SupportingDocument[]
  zohoConnection  ZohoConnection?
  reportSnapshots ReportSnapshot[]
  uploadedFiles   UploadedFile[]
  flagResponses   FlagResponse[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  analysisCredits     Int                  @default(3)
  lifetimeCreditsUsed Int                  @default(0)
  usedTxHashes        String[]             @default([])
  analysisSchedule    AnalysisSchedule?
  kotaniOrders        KotaniPaymentOrder[]
}

model BusinessMember {
  id         String       @id @default(cuid())
  businessId String
  userId     String
  role       BusinessRole @default(founder)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([businessId, userId])
  // Index on userId so listBusinessesForUser() and requireBusinessMember()
  // don't full-scan the table as membership count grows.
  @@index([userId])
}

model BusinessInvite {
  id          String       @id @default(cuid())
  businessId  String
  email       String
  role        BusinessRole @default(accountant)
  invitedById String
  acceptedAt  DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InvitedBy", fields: [invitedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([businessId, email])
  // Index on email so the createUser event (Google sign-in invite resolution)
  // doesn't full-scan the table on every new user creation.
  @@index([email])
}

model FlagResponse {
  id          String   @id @default(cuid())
  businessId  String
  flagTitle   String
  response    String
  respondedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, flagTitle])
  @@index([businessId])
}

model UploadedFile {
  id         String @id @default(cuid())
  businessId String

  filename   String
  fileKind   String
  rowCount   Int
  dateFrom   String?
  dateTo     String?
  uploadedAt DateTime @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
}

model Transaction {
  id              String   @id @default(cuid())
  businessId      String
  transactionId   String
  date            DateTime
  branch          String
  type            String
  accountName     String
  categoryName    String
  contactName     String
  referenceNumber String
  paymentMethod   String
  description     String
  amount          Float
  status          String
  bankAccount     String
  isReconciled    Boolean  @default(false)
  notes           String   @default("")

  sourceFileId String?
  sourceFile   UploadedFile? @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([businessId, transactionId])
  @@index([businessId])
  @@index([sourceFileId])
  // Composite index for date-range queries in cash_buffer analysis
  @@index([businessId, date])
}

model Invoice {
  id              String   @id @default(cuid())
  businessId      String
  invoiceId       String
  customerName    String
  total           Float
  balance         Float
  status          String
  date            DateTime
  dueDate         DateTime
  referenceNumber String
  branch          String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, invoiceId])
  @@index([businessId])
}

model BankStatement {
  id             String   @id @default(cuid())
  businessId     String
  statementId    String
  dateFrom       DateTime
  dateTo         DateTime
  openingBalance Float
  closingBalance Float
  reconciled     Boolean  @default(false)
  notes          String   @default("")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, statementId])
  @@index([businessId])
}

model SupportingDocument {
  id               String @id @default(cuid())
  businessId       String
  documentKind     String
  sourceFilename   String
  extractionMethod String
  confidence       String
  lineItemsJson    Json
  metadataJson     Json
  warningsJson     Json

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId])
}

model ZohoConnection {
  id             String  @id @default(cuid())
  businessId     String  @unique
  refreshToken   String
  apiDomain      String
  organizationId String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  connectedAt DateTime @default(now())
}

model GoogleSheetsConnection {
  id           String @id @default(cuid())
  userId       String @unique
  refreshToken String @db.Text
  email        String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectedAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalysisSchedule {
  id               String    @id @default(cuid())
  businessId       String    @unique
  frequency        String // "daily" | "weekly" | "biweekly" | "monthly"
  status           String    @default("active") // "active" | "paused"
  nextRunAt        DateTime
  lastRunAt        DateTime?
  lastRunStatus    String? // "success" | "failed" | "skipped_no_credits" | "skipped_no_zoho"
  lastRunError     String?
  additionalEmails String[]  @default([])

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite index for the cron query:
  // WHERE status = 'active' AND nextRunAt <= now()
  @@index([status, nextRunAt])
}

model KotaniPaymentOrder {
  id         String @id @default(cuid())
  businessId String
  userId     String

  packageId      String
  creditsToGrant Int
  amountKes      Int

  kotaniReferenceId String? @unique
  customerKey       String?

  // pending → deposit_received → completed | failed | expired
  status String @default("pending")

  depositStatus    String?
  onchainStatus    String?
  transactionHash  String? @unique // UNIQUE = idempotency guarantee
  cryptoAmountUsdc Float?

  rateId    String?
  rateValue String?

  initiatedAt DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime

  phoneNumber String
  ipAddress   String?

  business  Business         @relation(fields: [businessId], references: [id], onDelete: Restrict)
  user      User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  auditLogs KotaniAuditLog[]

  @@index([businessId])
  @@index([userId])
  @@index([status, expiresAt])
  @@index([kotaniReferenceId])
}

model KotaniAuditLog {
  id        String   @id @default(cuid())
  orderId   String
  event     String
  payload   Json?
  createdAt DateTime @default(now())

  order KotaniPaymentOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([createdAt])
}
